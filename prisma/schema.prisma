generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model acl_entity_permissions {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  entity_id     BigInt    @db.UnsignedBigInt
  entity_type   String    @db.VarChar(255)
  permission_id Int       @db.UnsignedMediumInt
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  @@index([permission_id], map: "idx_acl_entity_permissions_on_permission_id")
}

model acl_permissions {
  id          Int       @id @default(autoincrement()) @db.UnsignedMediumInt
  lft         Int       @default(0) @map("_lft") @db.UnsignedInt
  rgt         Int       @default(0) @map("_rgt") @db.UnsignedInt
  parent_id   Int?      @db.UnsignedInt
  name        String    @db.VarChar(200)
  key         String?   @db.VarChar(256)
  slug        String    @db.VarChar(250)
  description String?   @db.VarChar(250)
  icon        String?   @db.VarChar(100)
  tooltip     String?   @db.Text
  public      Boolean   @default(true)
  type        String    @default("DEFAULT") @db.VarChar(100)
  created_at  DateTime? @db.Timestamp(0)
  updated_at  DateTime? @db.Timestamp(0)

  @@index([lft, rgt, parent_id], map: "acl_permissions__lft__rgt_parent_id_index")
}

model acl_role_permissions {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  role_id       Int       @db.UnsignedInt
  permission_id Int       @db.UnsignedMediumInt
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  @@index([permission_id], map: "idx_acl_role_permissions_on_permission_id")
  @@index([role_id], map: "idx_acl_role_permissions_on_role_id")
}

model acl_roleables {
  id            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  role_id       Int       @db.UnsignedInt
  roleable_type String    @db.VarChar(255)
  roleable_id   BigInt    @db.UnsignedBigInt
  deleteable    Boolean   @default(false)
  created_at    DateTime? @db.Timestamp(0)
  updated_at    DateTime? @db.Timestamp(0)

  @@index([roleable_type, roleable_id], map: "acl_roleables_roleable_type_roleable_id_index")
  @@index([role_id], map: "idx_acl_role_permissions_on_role_id")
  @@index([roleable_id], map: "idx_acl_role_permissions_on_roleable_id")
}

model acl_roles {
  id             BigInt           @id @default(autoincrement()) @db.UnsignedBigInt
  name           String           @db.VarChar(255)
  key            String?          @db.VarChar(256)
  description    String?          @db.VarChar(255)
  slug           String           @db.VarChar(255)
  system         Boolean          @default(false)
  admin          Boolean          @default(false)
  ownerable_id   BigInt?          @db.UnsignedBigInt
  ownerable_type String?          @db.VarChar(255)
  status         acl_roles_status @default(ACTIVE)
  icon           String           @default("fa-person-military-pointing") @db.VarChar(60)
  created_at     DateTime?        @db.Timestamp(0)
  updated_at     DateTime?        @db.Timestamp(0)
}

model active_campaign_accounts {
  id         BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  api_url    String?   @db.VarChar(250)
  api_key    String?   @db.VarChar(250)
