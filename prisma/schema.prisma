model zapi_instances {
  id                       BigInt                @id @default(autoincrement()) @db.UnsignedBigInt
  workspace_id             BigInt                @db.UnsignedBigInt
  name                     String                @db.VarChar(255)
  code                     String?               @unique(map: "zapi_instances_code_unique") @db.VarChar(30)
  token                    String?               @db.VarChar(255)
  instance_id              String?               @db.VarChar(255)
  due                      DateTime?             @db.Timestamp(0)
  phone_number             String?               @db.VarChar(255)
  profile_name             String?               @db.VarChar(255)
  profile_picture          String?               @db.VarChar(1000)
  status                   zapi_instances_status @default(PENDING)
  fail_reason              String?               @db.VarChar(255)
  creator_id               BigInt                @db.UnsignedBigInt
  allow_in_feeder          Boolean               @default(false)
  auto_reply_automation_id BigInt?               @db.UnsignedBigInt
  auto_reply_interval      String                @default("247") @db.VarChar(255)
  created_at               DateTime?             @db.Timestamp(0)
  updated_at               DateTime?             @db.Timestamp(0)
  deleted_at               DateTime?             @db.Timestamp(0)

  @@index([code], map: "zapi_instances_code_index")
}

model zapi_messages {
  id                  BigInt                           @id @default(autoincrement()) @db.UnsignedBigInt
  zapi_chat_id        BigInt                           @db.UnsignedBigInt
  sender_id           BigInt?                          @db.UnsignedBigInt
  parent_id           BigInt?                          @db.UnsignedBigInt
  message_id          String?                          @db.VarChar(255)
  mobile_number       String                           @db.VarChar(255)
  type                String                           @db.VarChar(255)
  direction           zapi_messages_direction          @default(INCOMING)
  fromMe              Int                              @default(0) @db.TinyInt
  text                String?                          @db.LongText
  referral            String?                          @db.Text
  reply_to            BigInt?                          @db.UnsignedBigInt
  data                String?                          @db.LongText
  files               String?                          @db.LongText
  media               String?                          @db.LongText
  gallery_media_id    String?                          @db.VarChar(255)
  status              String                           @default("pending") @db.VarChar(255)
  remind_at           DateTime?                        @db.Timestamp(0)
  event_payload       String?                          @db.Text
  automation_queue_id BigInt?                          @db.UnsignedBigInt
  communication_mode  zapi_messages_communication_mode @default(INBOX)
  payload             String?                          @db.Text
  created_at          DateTime?                        @db.Timestamp(0)
  updated_at          DateTime?                        @db.Timestamp(0)
  error_data          String?                          @db.Text

  @@index([zapi_chat_id, created_at], map: "idx_zapi_messages_chat_created")
}

model zapi_statistics {
  id               BigInt                     @id @default(autoincrement()) @db.UnsignedBigInt
  workspace_id     BigInt                     @db.UnsignedBigInt
  zapi_instance_id BigInt?                    @db.UnsignedBigInt
  instance_name    String?                    @db.VarChar(255)
  direction        zapi_statistics_direction?
  message_type     String?                    @db.VarChar(255)
  created_at       DateTime                   @db.DateTime(0)

  @@index([zapi_instance_id, direction, created_at], map: "idx_zapi_stats_instance_direction_created")
}

