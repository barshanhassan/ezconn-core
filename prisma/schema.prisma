model workspace_usage {
  id             BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  workspace_id   BigInt    @db.UnsignedBigInt
  billing_month  Int       @default(0) @db.UnsignedInt
  billing_year   Int       @db.UnsignedInt
  start_date     DateTime  @db.DateTime(0)
  end_date       DateTime  @db.DateTime(0)
  agents         String?   @db.LongText
  contacts       String?   @db.LongText
  channels       String?   @db.LongText
  domain         String?   @db.LongText
  messages       String?   @db.LongText
  voice_credits  String?   @db.LongText
  currency       String    @default("USD") @db.Char(3)
  total          Decimal   @default(0.00) @db.Decimal(10, 2)
  total_in_cents BigInt    @default(0) @db.UnsignedBigInt
  media_id       BigInt?   @db.UnsignedBigInt
  media_url      BigInt?   @db.UnsignedBigInt
  created_at     DateTime? @db.Timestamp(0)
  updated_at     DateTime? @db.Timestamp(0)

  @@index([workspace_id], map: "idx_workspace_usage_on_workspace_id")
}

model workspaces {
  id                        BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  name                      String                    @db.VarChar(100)
  slug                      String                    @unique(map: "workspaces_slug_unique") @db.VarChar(150)
  agency_id                 BigInt                    @db.UnsignedBigInt
  contacts_counter          Int                       @db.UnsignedInt
  timezone                  String?                   @db.VarChar(255)
  first_day_week            workspaces_first_day_week @default(MONDAY)
  creator_id                BigInt?                   @db.UnsignedBigInt
  agency_agent_id           BigInt?                   @db.UnsignedBigInt
  allow_branding            Boolean                   @default(false)
  allow_agents              Boolean                   @default(false)
  allow_support             Boolean                   @default(false)
  buy_cal_accounts          Boolean                   @default(false)
  agents_limit              Int                       @default(0) @db.UnsignedSmallInt
  chatgpt_assistant_limit   Int                       @default(10) @db.UnsignedInt
  limited_contacts          Boolean                   @default(false)
  maximum_contacts          Int                       @default(0) @db.UnsignedInt
  maximum_contacts_notified Boolean                   @default(false)
  whatsapp_channels_limit   Int                       @default(1) @db.UnsignedInt
  instagram_channels_limit  Int                       @default(1) @db.UnsignedInt
  facebook_channels_limit   Int                       @default(1) @db.UnsignedInt
  telegram_channels_limit   Int                       @default(1) @db.UnsignedInt
  twilio_channels_limit     Int                       @default(1) @db.UnsignedInt
  evolution_channels_limit  Int                       @default(1) @db.UnsignedInt
  zapi_channels_limit       Int                       @default(0) @db.UnsignedInt
  webchat_channels_limit    Int                       @default(0) @db.UnsignedInt
  status                    workspaces_status         @default(ACTIVE)
  created_at                DateTime?                 @db.Timestamp(0)
  updated_at                DateTime?                 @db.Timestamp(0)
  deleted_at                DateTime?                 @db.Timestamp(0)
  is_data_imported          Boolean                   @default(false)

  @@index([agency_id], map: "idx_workspaces_on_agency_id")
  @@index([creator_id], map: "idx_workspaces_on_creator_id")
  @@index([status], map: "idx_workspaces_on_status")
}

